// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id          String   @id @default(cuid())
  title       String
  date        DateTime
  endDate     DateTime? // For CTO/FL, WFH, Travel entries - end date for expiration
  time        String
  timeEnd     String?  // End time for events (e.g., "14:00" for 2:00 PM)
  location    String?
  description String?
  status      String   @default("upcoming") // upcoming, ongoing, finished, cancelled
  category    String   @default("schedule") // schedule, cto, wfh, travel
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([category])
  @@index([status])
}

model AdminSetting {
  id        String @id @default(cuid())
  key       String @unique
  value     String
  updatedAt DateTime @updatedAt
}

model AdminPin {
  id        String @id @default(cuid())
  pinHash   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectRequest {
  id        String   @id @default(cuid())
  name      String
  number    String   // Project number as string for flexibility
  status    String?  // Optional: pending, approved, in-progress, on-hold, completed, cancelled (null means no status)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}
